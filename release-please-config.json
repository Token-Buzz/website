{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "draft": false,
  "prerelease": false,
  "separate-pull-requests": false,
  "changelog-sections": [
    { "type": "feat", "section": "🚀 Features" },
    { "type": "perf", "section": "🚀 Features" },
    { "type": "fix", "section": "🐛 Fixes" },
    { "type": "docs", "section": "📝 Documentation" },
    { "type": "chore", "section": "🧰 Maintenance" },
    { "type": "refactor", "section": "🧰 Maintenance" },
    { "type": "ci", "section": "🧰 Maintenance" },
    { "type": "test", "section": "🧰 Maintenance" },
    { "type": "build", "section": "🧰 Maintenance" },
    { "type": "style", "section": "🧰 Maintenance", "hidden": true }
  ],
  "packages": {
    ".": {
      "package-name": "tokenbuzz",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0"
    }
  }
}
