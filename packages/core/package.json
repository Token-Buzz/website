{
  "name": "@monorepo-template/core",
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "test": "sst shell vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "exports": {
    "./db/aggregates": "./src/db/aggregates.ts",
    "./db/bot-heuristic": "./src/db/bot-heuristic.ts",
    "./db/client": "./src/db/client.ts",
    "./db/geo": "./src/db/geo.ts",
    "./db/keys": "./src/db/keys.ts",
    "./db/keywords": "./src/db/keywords.ts",
    "./db/tokens": "./src/db/tokens.ts",
    "./db/tweets": "./src/db/tweets.ts",
    "./db/users": "./src/db/users.ts",
    "./lib/enrich": "./src/lib/enrich.ts",
    "./lib/twitter": "./src/lib/twitter.ts",
    "./movers": "./src/movers.ts",
    "./*": [
      "./src/*/index.ts",
      "./src/*.ts"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3",
    "@aws-sdk/lib-dynamodb": "^3",
    "node-rake": "^1.0.1",
    "sst": "*"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22",
    "@types/node": "^22",
    "dynalite": "^4.0.0",
    "typescript": "^5",
    "vitest": "^2"
  }
}
